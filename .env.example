# Firebase Configuration (Optional - falls back to localStorage if empty)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Google Gemini API Key (Required for ALL AI features: survey questions, chatbot, stress analysis)
# Get your free key at: https://aistudio.google.com/apikey
# This is loaded by the proxy server, NOT exposed to the browser
GEMINI_API_KEY=your_gemini_api_key_here
