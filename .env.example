# Google Gemini API Key (Required for ALL AI features)
# Get your free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# MongoDB Atlas Connection String (Required for database)
# Get from: MongoDB Atlas > Cluster > Connect > Drivers
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/soundmind?retryWrites=true&w=majority

# Google OAuth Client ID (Required for Google Sign-In)
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
